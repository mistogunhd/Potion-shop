{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "module": "CommonJS",  // Для тестов используем CommonJS
    "moduleResolution": "node",  // Для тестов используем node
    "types": ["jasmine", "node"]
  },
  "include": [
    "src/**/*.spec.ts",
    "src/**/*.d.ts"
  ]
}
